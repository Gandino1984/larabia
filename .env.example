# ============================================================
# larabia-magazine — environment variables
# Copy this to .env (gitignored) and fill in real values before
# running `docker compose up`.
# ============================================================

NODE_ENV=production

# ----- Database -----
MYSQL_DATABASE=larabia_db
MYSQL_USER=larabia
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# ----- Public hostnames -----
# Stage 1 (test on existing subdomain):
FRONT_VIRTUAL_HOST=larabia.uribarri.online
API_VIRTUAL_HOST=api.larabia.uribarri.online
# Stage 2 (own domain): set both to the new domain, e.g.
# FRONT_VIRTUAL_HOST=larabia.com
# API_VIRTUAL_HOST=api.larabia.com

# Used by the back-end to build links inside verification / password-reset emails.
FRONTEND_URL=https://larabia.uribarri.online

# Used by the front-end at build time to know where to POST API requests.
VITE_API_URL=https://api.larabia.uribarri.online

# nginx-proxy / Let's Encrypt companion notification email.
LETSENCRYPT_EMAIL=you@example.com

# ----- SMTP (verification + password reset + newsletter) -----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# Where the /contact form sends submissions. Falls back to EMAIL_USER if unset.
CONTACT_EMAIL=

# ----- Google OAuth -----
# Same client ID exposed to the browser as VITE_GOOGLE_CLIENT_ID (set automatically
# via docker-compose build args — no need to duplicate it here).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Super admin bootstrap -----
# Comma-separated list of emails that are automatically granted is_super_admin
# AND is_editor on every login (Google or local). Safe to leave broad — only
# whoever can actually authenticate as the email gets promoted. The check runs
# on every login so a wiped database re-promotes on next sign-in.
SUPER_ADMIN_EMAILS=andinogerman@gmail.com
