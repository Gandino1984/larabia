# Front-end build-time environment variables for larabia-magazine.
# Copy to .env (gitignored) and adjust for your environment.

# URL where the back-end API is reachable.
#   - Local dev:   http://localhost:3000
#   - Production:  https://api.larabia.uribarri.online
VITE_API_URL=http://localhost:3000

# Google OAuth client ID (the public one — same value used by the back-end's GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=
